# Copy to .env  ->  cp env.example .env  (then fill in)
# ---- Telegram ----
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-from-BotFather
# Comma-separated Telegram IDs allowed to run admin commands (get yours via /whoami)
ADMIN_TELEGRAM_IDS=123456789

# ---- Vision provider: gemini | openai | anthropic ----
PROVIDER=gemini
GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# Optional per-provider model override:
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---- Google Sheets ----
# Path to a Google service-account JSON key. Share your spreadsheet with its email as Editor.
GOOGLE_CREDENTIALS_FILE=./service_account.json
# The spreadsheet ID (the long string in the sheet URL between /d/ and /edit)
SPREADSHEET_ID=

# ---- Image handling ----
MAX_IMAGE_PX=1600
JPEG_QUALITY=80

# LOG_LEVEL=INFO
